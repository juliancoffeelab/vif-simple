(version 1.0)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs}))))))

(depends
 (all_platforms
  (ocaml dune seq re)))

(source
 (fetch
  (url https://github.com/Drup/tyre/archive/refs/tags/1.0.tar.gz)
  (checksum
   sha256=63ca1915da896640534b5cf928d220198709ec74b899d55b830fb0ceccebd633)))
